<view class="page">
  <view wx:if="{{loading}}" class="empty">加载中</view>
  <view wx:elif="{{!conversations.length}}" class="empty">暂无消息。匹配成功后会生成会话。</view>
  <view wx:for="{{conversations}}" wx:key="_id" class="card">
    <view class="row between">
      <view class="title">{{item.title}}</view>
      <view class="subtle">{{item.updatedAtText}}</view>
    </view>
    <view class="subtle preview">{{item.lastMessage}}</view>
  </view>
</view>
